{
  "$schema": "https://design-tokens.org",
  "description": "ODS 타이포그래피 토큰 — 위계별 스타일 정의",

  "fontFamily": {
    "primary": "'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "mono": "'JetBrains Mono', 'SF Mono', Consolas, monospace"
  },

  "fontWeight": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },

  "scale": {
    "display1": {
      "fontSize": "32px",
      "lineHeight": "40px",
      "fontWeight": "{fontWeight.bold}",
      "letterSpacing": "-0.4px",
      "usage": "히어로 영역, 메인 타이틀"
    },
    "display2": {
      "fontSize": "28px",
      "lineHeight": "36px",
      "fontWeight": "{fontWeight.bold}",
      "letterSpacing": "-0.3px",
      "usage": "섹션 대제목"
    },
    "heading1": {
      "fontSize": "24px",
      "lineHeight": "32px",
      "fontWeight": "{fontWeight.bold}",
      "letterSpacing": "-0.2px",
      "usage": "페이지 타이틀, 주요 섹션 헤딩"
    },
    "heading2": {
      "fontSize": "20px",
      "lineHeight": "28px",
      "fontWeight": "{fontWeight.semibold}",
      "letterSpacing": "-0.1px",
      "usage": "서브 섹션 헤딩, 카드 타이틀"
    },
    "heading3": {
      "fontSize": "17px",
      "lineHeight": "24px",
      "fontWeight": "{fontWeight.semibold}",
      "letterSpacing": "0",
      "usage": "리스트 아이템 타이틀, 소제목"
    },
    "body1": {
      "fontSize": "16px",
      "lineHeight": "24px",
      "fontWeight": "{fontWeight.regular}",
      "letterSpacing": "0",
      "usage": "본문 텍스트 (기본)"
    },
    "body1Strong": {
      "fontSize": "16px",
      "lineHeight": "24px",
      "fontWeight": "{fontWeight.medium}",
      "letterSpacing": "0",
      "usage": "본문 강조 텍스트"
    },
    "body2": {
      "fontSize": "14px",
      "lineHeight": "20px",
      "fontWeight": "{fontWeight.regular}",
      "letterSpacing": "0",
      "usage": "보조 텍스트, 설명"
    },
    "body2Strong": {
      "fontSize": "14px",
      "lineHeight": "20px",
      "fontWeight": "{fontWeight.medium}",
      "letterSpacing": "0",
      "usage": "보조 강조 텍스트, 버튼 레이블"
    },
    "caption1": {
      "fontSize": "12px",
      "lineHeight": "16px",
      "fontWeight": "{fontWeight.regular}",
      "letterSpacing": "0.1px",
      "usage": "캡션, 타임스탬프, 뱃지"
    },
    "caption2": {
      "fontSize": "11px",
      "lineHeight": "14px",
      "fontWeight": "{fontWeight.medium}",
      "letterSpacing": "0.2px",
      "usage": "최소 텍스트, 라벨"
    }
  },

  "rules": {
    "maxLineLength": "본문 기준 최대 40자(한글) / 80자(영문) 권장",
    "paragraphSpacing": "본문 문단 간격은 line-height의 50% (12px)",
    "minimumSize": "접근성을 위해 최소 11px (caption2) 이하 사용 금지"
  }
}
